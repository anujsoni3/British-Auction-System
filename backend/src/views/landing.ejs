<%- include('partials/head') %>
<section class="p-4 p-md-5 mb-4 rounded-4 shadow-sm reveal-up" style="background: linear-gradient(135deg, #0f3f36 0%, #1e6b5d 55%, #d8efe8 100%);">
  <div class="row align-items-center g-4">
    <div class="col-lg-8 text-white">
      <p class="text-uppercase fw-bold mb-2" style="letter-spacing: 0.08em;">Procurement Intelligence</p>
      <h1 class="display-5 fw-bold mb-3">Smart RFQ British Auction System</h1>
      <p class="lead mb-4">Drive competitive supplier pricing with dynamic auction extensions</p>
      <div class="d-flex flex-wrap align-items-center gap-2">
        <a href="/rfqs" class="btn btn-light btn-lg fw-semibold px-4">View Auctions</a>
        <a href="/rfqs/new" class="btn btn-outline-light btn-sm">Get Started</a>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm reveal-up reveal-delay-1">
        <div class="card-body p-4">
          <div class="d-flex align-items-center gap-3 mb-3">
            <span class="bg-success-subtle text-success rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 2.25rem; height: 2.25rem;">
              <i class="bi bi-graph-up-arrow"></i>
            </span>
            <div class="fw-bold">Live Auction Momentum</div>
          </div>
          <p class="text-secondary mb-0">Supplier bids, ranking shifts, and extension triggers are visible instantly to keep procurement fair and competitive.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mb-5 reveal-up reveal-delay-1">
  <div class="d-flex align-items-center gap-2 mb-3">
    <i class="bi bi-diagram-3 text-success"></i>
    <h2 class="h3 fw-bold mb-0">How It Works</h2>
  </div>
  <div class="row g-3 g-md-4">
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-1">
        <div class="card-body">
          <div class="badge text-bg-success mb-2">Step 1</div>
          <h3 class="h5 fw-bold">Create RFQ</h3>
          <p class="text-secondary mb-0">Buyer defines timeline, trigger window, and extension policy.</p>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-2">
        <div class="card-body">
          <div class="badge text-bg-success mb-2">Step 2</div>
          <h3 class="h5 fw-bold">Suppliers place bids</h3>
          <p class="text-secondary mb-0">Vendors submit competitive offers with full pricing breakup.</p>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-3">
        <div class="card-body">
          <div class="badge text-bg-success mb-2">Step 3</div>
          <h3 class="h5 fw-bold">Rankings update in real-time</h3>
          <p class="text-secondary mb-0">Every valid bid updates supplier position (L1, L2, L3...).</p>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-3">
        <div class="card-body">
          <div class="badge text-bg-success mb-2">Step 4</div>
          <h3 class="h5 fw-bold">Auction auto-extends on activity</h3>
          <p class="text-secondary mb-0">Last-minute actions can trigger a transparent extension window.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mb-5 reveal-up reveal-delay-1">
  <div class="d-flex align-items-center gap-2 mb-3">
    <i class="bi bi-stars text-success"></i>
    <h2 class="h3 fw-bold mb-0">Key Features</h2>
  </div>
  <div class="row g-3 g-md-4">
    <div class="col-12 col-md-6">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-1">
        <div class="card-body d-flex gap-3">
          <i class="bi bi-eye-fill text-success fs-4"></i>
          <div>
            <h3 class="h5 fw-bold">Transparent bidding</h3>
            <p class="text-secondary mb-0">All participants operate in a consistent and auditable auction flow.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-6">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-2">
        <div class="card-body d-flex gap-3">
          <i class="bi bi-clock-history text-success fs-4"></i>
          <div>
            <h3 class="h5 fw-bold">Automatic time extension</h3>
            <p class="text-secondary mb-0">Trigger-based extensions protect fairness near the closing window.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-6">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-2">
        <div class="card-body d-flex gap-3">
          <i class="bi bi-trophy-fill text-success fs-4"></i>
          <div>
            <h3 class="h5 fw-bold">Supplier ranking (L1, L2...)</h3>
            <p class="text-secondary mb-0">Decision makers always see the current best bid and order.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-6">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-3">
        <div class="card-body d-flex gap-3">
          <i class="bi bi-shield-lock-fill text-success fs-4"></i>
          <div>
            <h3 class="h5 fw-bold">Forced close protection</h3>
            <p class="text-secondary mb-0">A hard stop ensures auctions close on policy, no matter extension events.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mb-4 reveal-up reveal-delay-2">
  <div class="d-flex align-items-center gap-2 mb-3">
    <i class="bi bi-briefcase-fill text-success"></i>
    <h2 class="h3 fw-bold mb-0">Business Value</h2>
  </div>
  <div class="row g-3 g-md-4">
    <div class="col-12 col-md-4">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-1">
        <div class="card-body">
          <h3 class="h5 fw-bold">Better pricing</h3>
          <p class="text-secondary mb-0">More dynamic competition pushes bids toward optimal procurement rates.</p>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-4">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-2">
        <div class="card-body">
          <h3 class="h5 fw-bold">Fair competition</h3>
          <p class="text-secondary mb-0">Uniform rules and transparent ranking make supplier participation trustworthy.</p>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-4">
      <div class="card h-100 border-0 shadow-sm reveal-up reveal-delay-3">
        <div class="card-body">
          <h3 class="h5 fw-bold">Prevents last-minute bidding</h3>
          <p class="text-secondary mb-0">Activity-triggered extension reduces end-window sniping behavior.</p>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('partials/foot') %>
