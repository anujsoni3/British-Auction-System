<%- include('partials/head') %>
<div class="d-flex justify-content-between align-items-end mb-3">
  <div>
    <p class="text-uppercase text-secondary fw-bold mb-1">Auction listing</p>
    <h1 class="display-6 fw-bold">British Auctions</h1>
  </div>
  <a href="/rfqs/new" class="btn btn-success">New RFQ</a>
</div>

<% if (rfqs.length === 0) { %>
  <div class="alert alert-light border text-center text-secondary py-4">No RFQs yet.</div>
<% } %>

<div class="row g-4">
  <% rfqs.forEach((rfq) => { %>
    <%
      const statusMeta = {
        ACTIVE: { label: 'Active', className: 'text-bg-success', icon: '🟢' },
        CLOSED: { label: 'Closed', className: 'text-bg-danger', icon: '🔴' },
        FORCE_CLOSED: { label: 'Force Closed', className: 'status-force-closed', icon: '⚫' },
        SCHEDULED: { label: 'Scheduled', className: 'text-bg-secondary', icon: '⏳' }
      }[rfq.status] || { label: rfq.status.replaceAll('_', ' '), className: 'text-bg-secondary', icon: 'ℹ️' };
    %>
    <div class="col-12 col-md-6 col-xl-4">
      <article class="card rfq-card h-100 border-0 shadow-sm">
        <div class="card-body d-flex flex-column gap-3 p-4">
          <div class="d-flex justify-content-between align-items-start gap-2">
            <h2 class="h5 fw-bold mb-0"><%= rfq.name %></h2>
            <span class="badge <%= statusMeta.className %>"><%= statusMeta.icon %> <%= statusMeta.label %></span>
          </div>

          <div class="row g-3">
            <div class="col-6">
              <div class="rfq-metric-label">Lowest Bid</div>
              <div class="rfq-metric-value"><%= rfq.lowestBid ? Number(rfq.lowestBid).toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }) : 'No bids' %></div>
            </div>
            <div class="col-6">
              <div class="rfq-metric-label">Time Left</div>
              <div class="rfq-metric-value"><span data-countdown="<%= rfq.bidCloseTime.toISOString() %>" data-status="<%= rfq.status %>"></span></div>
            </div>
            <div class="col-6">
              <div class="rfq-metric-label">Bids</div>
              <div class="rfq-metric-value"><%= rfq.bidCount %></div>
            </div>
            <div class="col-6">
              <div class="rfq-metric-label">Extensions</div>
              <div class="rfq-metric-value"><%= rfq.extensionCount %></div>
            </div>
          </div>

          <div class="small text-secondary bg-light rounded-3 p-3">
            <span class="fw-semibold">🧾 Codex Prompt:</span>
            Review this RFQ for trigger-window bids and validate extension behavior.
          </div>

          <div class="mt-auto pt-2 border-top d-flex justify-content-between align-items-center">
            <small class="text-secondary">Closes <%= new Date(rfq.bidCloseTime).toLocaleString('en-IN') %></small>
            <a class="btn btn-success btn-sm" href="/rfqs/<%= rfq.id %>">View Details</a>
          </div>
        </div>
      </article>
    </div>
  <% }) %>
</div>
<%- include('partials/foot') %>
