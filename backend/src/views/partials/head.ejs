<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>British Auction RFQ</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
      body { background: #f5f7f8; }
      .navbar { background: #0f3f36; }
      .rfq-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .rfq-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 1rem 2rem rgba(20, 35, 31, 0.12) !important;
      }
      .rfq-metric-label {
        color: #64756f;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .rfq-metric-value {
        color: #14231f;
        font-size: 1rem;
        font-weight: 700;
      }
      .rank-l1 { background: #dff5e9; }
      .rank-l1 td { border-color: #badfca; }
      .rank-l1 .rank-badge { background: #28a745; color: white; box-shadow: 0 0 0.5rem rgba(40, 167, 69, 0.3); }
      .rank-table tbody tr {
        transition: background-color 0.2s ease;
      }
      .rank-table tbody tr:hover {
        background-color: #f9f9f9;
      }
      .section-label {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.8rem;
        color: #3f5e55;
        font-size: 0.84rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .section-shell {
        border: 1px solid #e2e9e6;
        border-radius: 0.95rem;
        background: #fff;
        transition: box-shadow 0.2s ease;
      }
      .section-shell:hover {
        box-shadow: 0 0.5rem 1.2rem rgba(20, 35, 31, 0.08) !important;
      }
      .summary-card-soft {
        border: 1px solid #e2e9e6;
        box-shadow: 0 0.45rem 1.1rem rgba(20, 35, 31, 0.05);
      }
      .status-pill { border-radius: 999px; padding: 0.35rem 0.7rem; font-weight: 700; }
      .status-force-closed { background: #212529; color: #fff; }
      .summary-card { border: 0; box-shadow: 0 0.75rem 1.75rem rgba(20, 35, 31, 0.08); }
      .metric-label { color: #64756f; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; }
      .metric-value { font-size: 1.35rem; font-weight: 800; color: #14231f; }
      .timeline { position: relative; }
      .timeline-item { position: relative; padding: 0 0 1rem 2.1rem; border-left: 2px solid #dce5e1; margin-left: 0.6rem; }
      .timeline-item:last-child { border-left-color: transparent; }
      .timeline-dot { position: absolute; left: -0.7rem; top: 0; width: 1.25rem; height: 1.25rem; border-radius: 999px; display: grid; place-items: center; color: #fff; font-size: 0.72rem; }
      .dot-created { background: #198754; }
      .dot-bid { background: #0d6efd; }
      .dot-extended { background: #fd7e14; }
      .dot-status { background: #6f42c1; }
      .reveal-up {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.55s ease, transform 0.55s ease;
      }
      .reveal-up.is-visible {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-delay-1 { transition-delay: 0.08s; }
      .reveal-delay-2 { transition-delay: 0.16s; }
      .reveal-delay-3 { transition-delay: 0.24s; }
      @media (prefers-reduced-motion: reduce) {
        .reveal-up {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark mb-4">
      <div class="container d-flex justify-content-between align-items-center gap-2">
        <a class="navbar-brand fw-bold" href="/">British Auction RFQ</a>
        <div class="d-flex align-items-center gap-2">
          <a class="btn btn-outline-light btn-sm" href="/">Home</a>
          <a class="btn btn-outline-light btn-sm" href="/rfqs">Auctions</a>
          <a class="btn btn-light btn-sm" href="/rfqs/new">Create RFQ</a>
        </div>
      </div>
    </nav>
    <main class="container pb-5">
