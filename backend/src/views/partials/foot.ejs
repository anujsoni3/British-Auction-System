    </main>
    <script>
      const shouldAutoRefresh = document.body.dataset.autoRefresh === 'true';
      if (shouldAutoRefresh) {
        setInterval(() => window.location.reload(), 10000);
      }

      document.querySelectorAll('[data-countdown]').forEach((element) => {
        const closeTime = new Date(element.dataset.countdown).getTime();
        const status = element.dataset.status;
        function tick() {
          if (status !== 'ACTIVE') {
            element.textContent = status.replace('_', ' ');
            return;
          }
          const diff = closeTime - Date.now();
          if (diff <= 0) {
            element.textContent = 'Close check due';
            return;
          }
          const minutes = Math.floor(diff / 60000);
          const seconds = Math.floor((diff % 60000) / 1000);
          element.textContent = `${minutes}m ${String(seconds).padStart(2, '0')}s`;
        }
        tick();
        setInterval(tick, 1000);
      });

      const revealItems = document.querySelectorAll('.reveal-up');
      if (revealItems.length > 0) {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion) {
          revealItems.forEach((item) => item.classList.add('is-visible'));
        } else {
          const observer = new IntersectionObserver((entries, currentObserver) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                currentObserver.unobserve(entry.target);
              }
            });
          }, { threshold: 0.15 });
          revealItems.forEach((item) => observer.observe(item));
        }
      }
    </script>
  </body>
</html>
