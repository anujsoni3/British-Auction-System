<%- include('partials/head') %>
<h1 class="display-6 fw-bold mb-3">Create British Auction RFQ</h1>
<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
<form class="card shadow-sm p-4" method="post" action="/rfqs">
  <div class="mb-3">
    <label class="form-label">RFQ Name</label>
    <input class="form-control" name="name" value="<%= values.name || '' %>" required>
  </div>
  <div class="row g-3">
    <div class="col-md-4">
      <label class="form-label">Bid Start Time</label>
      <input class="form-control" type="datetime-local" name="bidStartTime" value="<%= values.bidStartTime || '' %>" required>
    </div>
    <div class="col-md-4">
      <label class="form-label">Bid Close Time</label>
      <input class="form-control" type="datetime-local" name="bidCloseTime" value="<%= values.bidCloseTime || '' %>" required>
    </div>
    <div class="col-md-4">
      <label class="form-label">Forced Close Time</label>
      <input class="form-control" type="datetime-local" name="forcedCloseTime" value="<%= values.forcedCloseTime || '' %>" required>
    </div>
    <div class="col-md-4">
      <label class="form-label">Trigger Window Minutes</label>
      <input class="form-control" type="number" min="1" name="triggerWindowMinutes" value="<%= values.triggerWindowMinutes || 10 %>" required>
    </div>
    <div class="col-md-4">
      <label class="form-label">Extension Minutes</label>
      <input class="form-control" type="number" min="1" name="extensionMinutes" value="<%= values.extensionMinutes || 5 %>" required>
    </div>
    <div class="col-md-4">
      <label class="form-label">Trigger Type</label>
      <select class="form-select" name="triggerType">
        <% ['ANY_BID', 'ANY_RANK_CHANGE', 'L1_CHANGE'].forEach((type) => { %>
          <option value="<%= type %>" <%= values.triggerType === type ? 'selected' : '' %>><%= type.replaceAll('_', ' ') %></option>
        <% }) %>
      </select>
    </div>
  </div>
  <div class="mt-4 d-flex gap-2">
    <button class="btn btn-success" type="submit">Create RFQ</button>
    <a class="btn btn-outline-secondary" href="/rfqs">Cancel</a>
  </div>
</form>
<%- include('partials/foot') %>
