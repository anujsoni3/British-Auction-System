<%- include('partials/head') %>
<% const money = (value) => Number(value || 0).toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }); %>
<%
  const statusBadge = {
    ACTIVE: { label: 'ACTIVE', emoji: '🟢', className: 'text-bg-success' },
    CLOSED: { label: 'CLOSED', emoji: '🔴', className: 'text-bg-danger' },
    FORCE_CLOSED: { label: 'FORCE CLOSED', emoji: '⚫', className: 'status-force-closed' },
    SCHEDULED: { label: 'SCHEDULED', emoji: '⏳', className: 'text-bg-secondary' }
  }[rfq.status] || { label: rfq.status.replaceAll('_', ' '), emoji: 'ℹ️', className: 'text-bg-secondary' };
%>

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
  <div>
    <span id="statusBadge" class="badge <%= statusBadge.className %> mb-2"><%= statusBadge.emoji %> <%= statusBadge.label %></span>
    <h1 class="display-6 fw-bold mb-1"><%= rfq.name %></h1>
    <p class="text-secondary mb-0">Trigger: <%= rfq.triggerType.replaceAll('_', ' ') %> | Window: <%= rfq.triggerWindowMinutes %>m | Extension: <%= rfq.extensionMinutes %>m</p>
  </div>
  <form method="post" action="/rfqs/<%= rfq.id %>/close-check">
    <button class="btn btn-outline-primary btn-sm" type="submit">Run Close Check</button>
  </form>
</div>

<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

<div class="section-label"><i class="bi bi-speedometer2"></i> Live Summary</div>
<div class="row g-3 mb-4">
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card h-100 summary-card-soft">
      <div class="card-body">
        <div class="rfq-metric-label"><i class="bi bi-trophy"></i> L1 Supplier</div>
        <div id="summaryL1" class="metric-value"><%= summary.l1Supplier %></div>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card h-100 summary-card-soft">
      <div class="card-body">
        <div class="rfq-metric-label"><i class="bi bi-cash-coin"></i> Lowest Price</div>
        <div id="summaryPrice" class="metric-value"><%= summary.finalPrice ? money(summary.finalPrice) : 'No bids' %></div>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card h-100 summary-card-soft">
      <div class="card-body">
        <div class="rfq-metric-label"><i class="bi bi-percent"></i> Savings</div>
        <div id="summarySavingsPercent" class="metric-value text-success"><%= summary.savingsPercent.toFixed(1) %>%</div>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card h-100 summary-card-soft">
      <div class="card-body">
        <div class="rfq-metric-label"><i class="bi bi-hourglass-split"></i> Time Left</div>
        <div id="summaryTimeLeft" class="metric-value" style="font-family: 'Monaco', 'Courier New', monospace; font-size: 0.95rem;">--:--:--</div>
      </div>
    </div>
  </div>
</div>

<div class="section-label"><i class="bi bi-grid"></i> Rankings & Bidding</div>
<div class="row g-4 mb-4">
  <div class="col-lg-8">
    <section class="section-shell shadow-sm">
      <div class="card-header fw-bold bg-white border-0 pt-4 px-4 pb-2">📊 Rankings Table</div>
      <div class="table-responsive px-2 pb-3">
        <table class="table align-middle mb-0 rank-table">
          <thead class="table-light">
            <tr>
              <th><i class="bi bi-list-ol"></i> Rank</th>
              <th><i class="bi bi-building"></i> Supplier</th>
              <th><i class="bi bi-box-seam"></i> Freight</th>
              <th><i class="bi bi-geo-alt"></i> Origin</th>
              <th><i class="bi bi-geo-alt"></i> Destination</th>
              <th><i class="bi bi-cash-coin"></i> Total Price</th>
              <th><i class="bi bi-clock"></i> Transit</th>
            </tr>
          </thead>
          <tbody id="rankingsBody">
            <% if (rankings.length === 0) { %>
              <tr><td colspan="7" class="text-center text-secondary py-4">No bids yet. Be the first to place a bid.</td></tr>
            <% } %>
            <% rankings.forEach((bid) => { %>
              <tr class="<%= bid.rank === 'L1' ? 'rank-l1' : '' %>">
                <td><span class="badge text-bg-dark"><%= bid.rank %></span></td>
                <td class="fw-bold"><%= bid.supplier.name %></td>
                <td><%= money(bid.freightCharges) %></td>
                <td><%= money(bid.originCharges) %></td>
                <td><%= money(bid.destinationCharges) %></td>
                <td class="fw-bold"><%= money(bid.price) %></td>
                <td><%= bid.transitTime %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <div class="col-lg-4">
    <section class="section-shell shadow-sm p-4 h-100">
      <h2 class="h5 fw-bold mb-3"><i class="bi bi-cash-coin"></i> Bid Form</h2>
      <div id="bidFeedback"></div>
      <form id="bidForm" method="post" action="/rfqs/<%= rfq.id %>/bid">
        <div class="mb-3">
          <label class="form-label"><i class="bi bi-building"></i> Supplier Name</label>
          <input class="form-control" name="supplierName" required>
        </div>
        <div class="mb-3">
          <label class="form-label"><i class="bi bi-box-seam"></i> Freight Charges</label>
          <input class="form-control" type="number" min="0" step="0.01" name="freightCharges" required>
        </div>
        <div class="mb-3">
          <label class="form-label"><i class="bi bi-geo-alt"></i> Origin Charges</label>
          <input class="form-control" type="number" min="0" step="0.01" name="originCharges" required>
        </div>
        <div class="mb-3">
          <label class="form-label"><i class="bi bi-geo-alt"></i> Destination Charges</label>
          <input class="form-control" type="number" min="0" step="0.01" name="destinationCharges" required>
        </div>
        <div class="mb-3">
          <label class="form-label"><i class="bi bi-clock"></i> Transit Time</label>
          <input class="form-control" name="transitTime" placeholder="3 days" required>
        </div>
        <button id="submitBidBtn" class="btn btn-success w-100" type="submit">
          <i class="bi bi-check-circle"></i> Submit Bid
        </button>
      </form>
    </section>
  </div>
</div>

<div class="section-label"><i class="bi bi-lightbulb"></i> How This Auction Works</div>
<div class="alert alert-info border-0 mb-4">
  <div class="row g-3">
    <div class="col-md-4">
      <div>
        <strong><i class="bi bi-window-sidebar"></i> Trigger Window</strong>
        <div class="small text-secondary mt-1">
          Last <%= rfq.triggerWindowMinutes %> minute<%= rfq.triggerWindowMinutes !== 1 ? 's' : '' %> before close
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div>
        <strong><i class="bi bi-arrow-repeat"></i> Extension Duration</strong>
        <div class="small text-secondary mt-1">
          Auction extends by <%= rfq.extensionMinutes %> minute<%= rfq.extensionMinutes !== 1 ? 's' : '' %> when triggered
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div>
        <strong><i class="bi bi-lightning-fill"></i> Trigger Type</strong>
        <div class="small text-secondary mt-1">
          <%= rfq.triggerType.replaceAll('_', ' ').toLowerCase() %>
        </div>
      </div>
    </div>
  </div>
  <div class="mt-2 small">
    <strong>How it works:</strong> If a bid is placed or ranking changes within the trigger window, the auction automatically extends by the specified duration. The auction will never extend beyond the forced close time.
  </div>
</div>

<div class="section-label"><i class="bi bi-activity"></i> Timeline & Logs</div>
<div class="row g-4">
  <div class="col-lg-7">
    <section class="section-shell shadow-sm p-4 h-100">
      <h2 class="h5 fw-bold mb-3">📜 Timeline</h2>
      <div id="timelineList" class="timeline">
        <% logs.forEach((log) => { %>
          <% const dotClass = log.eventType === 'RFQ_CREATED' ? 'dot-created' : log.eventType === 'BID_PLACED' ? 'dot-bid' : log.eventType === 'AUCTION_EXTENDED' ? 'dot-extended' : 'dot-status'; %>
          <% const dotText = log.eventType === 'RFQ_CREATED' ? '✓' : log.eventType === 'BID_PLACED' ? '₹' : log.eventType === 'AUCTION_EXTENDED' ? '+' : 'i'; %>
          <div class="timeline-item">
            <span class="timeline-dot <%= dotClass %>"><%= dotText %></span>
            <div class="fw-bold"><%= log.eventType.replaceAll('_', ' ') %></div>
            <div><%= log.message %></div>
            <small class="text-secondary"><%= new Date(log.createdAt).toLocaleString('en-IN') %></small>
          </div>
        <% }) %>
      </div>
    </section>
  </div>

  <div class="col-lg-5">
    <section class="section-shell shadow-sm p-4 mb-4">
      <h2 class="h5 fw-bold mb-3">🧾 Logs</h2>
      <div id="logsList" class="d-flex flex-column gap-2">
        <% if (logs.length === 0) { %>
          <div class="text-secondary">No logs yet.</div>
        <% } %>
        <% logs.slice(0, 8).forEach((log) => { %>
          <div class="border rounded-3 p-2">
            <div class="small fw-semibold"><%= log.eventType.replaceAll('_', ' ') %></div>
            <div class="small text-secondary"><%= new Date(log.createdAt).toLocaleString('en-IN') %></div>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="section-shell shadow-sm p-4">
      <h2 class="h5 fw-bold mb-3">🧾 Codex Prompt</h2>
      <p class="small text-secondary mb-2">Use this to evaluate live auction behavior:</p>
      <div class="bg-light rounded-3 p-3 small" id="codexPromptBox">
        Analyze RFQ <%= rfq.name %> for live ranking changes, extension triggers, and final close behavior with audit-ready reasoning.
      </div>
    </section>
  </div>
</div>

<script src="https://cdn.socket.io/4.7.5/socket.io.min.js" crossorigin="anonymous"></script>
<script>
  (() => {
    const rfqId = '<%= rfq.id %>';
    let currentStatus = '<%= rfq.status %>';
    let currentCloseTime = '<%= rfq.bidCloseTime.toISOString() %>';

    const summaryL1 = document.getElementById('summaryL1');
    const summaryPrice = document.getElementById('summaryPrice');
    const summarySavingsPercent = document.getElementById('summarySavingsPercent');
    const summaryTimeLeft = document.getElementById('summaryTimeLeft');
    const rankingsBody = document.getElementById('rankingsBody');
    const timelineList = document.getElementById('timelineList');
    const logsList = document.getElementById('logsList');
    const statusBadge = document.getElementById('statusBadge');
    const codexPromptBox = document.getElementById('codexPromptBox');

    const statusUi = {
      ACTIVE: { label: 'ACTIVE', emoji: '🟢', className: 'text-bg-success' },
      CLOSED: { label: 'CLOSED', emoji: '🔴', className: 'text-bg-danger' },
      FORCE_CLOSED: { label: 'FORCE CLOSED', emoji: '⚫', className: 'status-force-closed' },
      SCHEDULED: { label: 'SCHEDULED', emoji: '⏳', className: 'text-bg-secondary' }
    };

    function money(value) {
      const number = Number(value || 0);
      return number.toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
    }

    function setStatusBadge(status) {
      const meta = statusUi[status] || { label: String(status).replaceAll('_', ' '), emoji: 'ℹ️', className: 'text-bg-secondary' };
      statusBadge.className = `badge ${meta.className} mb-2`;
      statusBadge.textContent = `${meta.emoji} ${meta.label}`;
    }

    function renderTimeLeft() {
      if (currentStatus !== 'ACTIVE') {
        summaryTimeLeft.textContent = currentStatus.replaceAll('_', ' ');
        return;
      }
      const diff = new Date(currentCloseTime).getTime() - Date.now();
      if (diff <= 0) {
        summaryTimeLeft.textContent = '00:00:00';
        summaryTimeLeft.style.color = '#dc3545';
        return;
      }
      const totalSeconds = Math.floor(diff / 1000);
      const hours = Math.floor(totalSeconds / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;
      
      const isNearClose = diff < (rfq.triggerWindowMinutes * 60 * 1000);
      summaryTimeLeft.style.color = isNearClose ? '#ffc107' : '#28a745';
      summaryTimeLeft.textContent = `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
    }

    function dotMeta(eventType) {
      if (eventType === 'RFQ_CREATED') return { className: 'dot-created', text: '✓' };
      if (eventType === 'BID_PLACED') return { className: 'dot-bid', text: '₹' };
      if (eventType === 'AUCTION_EXTENDED') return { className: 'dot-extended', text: '+' };
      return { className: 'dot-status', text: 'i' };
    }

    function renderRankings(rankings) {
      if (!Array.isArray(rankings) || rankings.length === 0) {
        rankingsBody.innerHTML = '<tr><td colspan="7" class="text-center text-secondary py-4">No bids yet. Be the first to place a bid.</td></tr>';
        return;
      }

      rankingsBody.innerHTML = rankings.map((bid) => {
        const l1Class = bid.rank === 'L1' ? 'rank-l1' : '';
        const rankColor = bid.rank === 'L1' ? 'success' : bid.rank === 'L2' ? 'primary' : bid.rank === 'L3' ? 'info' : 'secondary';
        return `
          <tr class="${l1Class}">
            <td><span class="badge text-bg-${rankColor} rank-badge"><i class="bi bi-trophy"></i> ${bid.rank}</span></td>
            <td class="fw-bold">${bid.supplier.name}</td>
            <td>${money(bid.freightCharges)}</td>
            <td>${money(bid.originCharges)}</td>
            <td>${money(bid.destinationCharges)}</td>
            <td class="fw-bold text-success">${money(bid.price)}</td>
            <td><i class="bi bi-clock"></i> ${bid.transitTime}</td>
          </tr>
        `;
      }).join('');
    }

    function renderTimeline(logs) {
      if (!Array.isArray(logs) || logs.length === 0) {
        timelineList.innerHTML = '<div class="text-secondary">No timeline events yet.</div>';
        return;
      }

      timelineList.innerHTML = logs.map((log) => {
        const meta = dotMeta(log.eventType);
        const createdAt = new Date(log.createdAt).toLocaleString('en-IN');
        const icons = {
          'RFQ_CREATED': '✓',
          'BID_PLACED': '💰',
          'AUCTION_EXTENDED': '⚡',
          'STATUS_UPDATED': 'ℹ️'
        };
        return `
          <div class="timeline-item">
            <span class="timeline-dot ${meta.className}">${icons[log.eventType] || meta.text}</span>
            <div class="fw-bold text-capitalize">${String(log.eventType).replaceAll('_', ' ').toLowerCase()}</div>
            <div class="small">${log.message}</div>
            <small class="text-secondary"><i class="bi bi-clock"></i> ${createdAt}</small>
          </div>
        `;
      }).join('');
    }

    function renderLogs(logs) {
      if (!Array.isArray(logs) || logs.length === 0) {
        logsList.innerHTML = '<div class="text-secondary">No logs yet.</div>';
        return;
      }

      const eventIcons = {
        'RFQ_CREATED': '<i class="bi bi-plus-circle text-success"></i>',
        'BID_PLACED': '<i class="bi bi-cash-coin text-primary"></i>',
        'AUCTION_EXTENDED': '<i class="bi bi-arrow-repeat text-warning"></i>',
        'STATUS_UPDATED': '<i class="bi bi-arrow-clockwise text-info"></i>'
      };

      logsList.innerHTML = logs.slice(0, 8).map((log) => {
        const createdAt = new Date(log.createdAt).toLocaleString('en-IN');
        const icon = eventIcons[log.eventType] || '<i class="bi bi-info-circle"></i>';
        return `
          <div class="border rounded-3 p-2">
            <div class="small fw-semibold">${icon} ${String(log.eventType).replaceAll('_', ' ')}</div>
            <div class="small text-secondary"><i class="bi bi-clock"></i> ${createdAt}</div>
          </div>
        `;
      }).join('');
    }

    async function refreshRfqDetails() {
      try {
        const response = await fetch(`/api/rfqs/${rfqId}`);
        if (!response.ok) return;

        const details = await response.json();
        currentStatus = details.rfq.status;
        currentCloseTime = details.rfq.bidCloseTime;

        setStatusBadge(details.rfq.status);
        summaryL1.textContent = details.summary.l1Supplier;
        summaryPrice.textContent = details.summary.finalPrice ? money(details.summary.finalPrice) : 'No bids';
        summarySavingsPercent.textContent = `${Number(details.summary.savingsPercent || 0).toFixed(1)}%`;
        codexPromptBox.textContent = `Analyze RFQ ${details.rfq.name} for live ranking changes, extension triggers, and final close behavior with audit-ready reasoning.`;

        renderRankings(details.rankings);
        renderTimeline(details.logs);
        renderLogs(details.logs);
        renderTimeLeft();
      } catch (_err) {
        // Ignore transient refresh errors to keep the form responsive.
      }
    }

    renderTimeLeft();
    setInterval(renderTimeLeft, 1000);

    // Bid form handling with loading feedback
    const bidForm = document.getElementById('bidForm');
    const submitBidBtn = document.getElementById('submitBidBtn');
    const bidFeedback = document.getElementById('bidFeedback');

    bidForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBidBtn.disabled = true;
      const originalText = submitBidBtn.innerHTML;
      submitBidBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Submitting bid...';

      const formData = new FormData(bidForm);
      try {
        const response = await fetch(bidForm.action, {
          method: 'POST',
          body: formData
        });

        if (response.ok) {
          bidFeedback.innerHTML = '<div class="alert alert-success alert-dismissible fade show" role="alert"><i class="bi bi-check-circle"></i> <strong>Success!</strong> Bid placed successfully. <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
          bidForm.reset();
          setTimeout(() => refreshRfqDetails(), 500);
        } else {
          const contentType = response.headers.get('content-type');
          let errorMsg = 'Failed to place bid';
          if (contentType && contentType.includes('text/html')) {
            const html = await response.text();
            const match = html.match(/<div class="alert alert-danger">(.*?)<\/div>/);
            if (match) errorMsg = match[1];
          } else {
            try {
              const json = await response.json();
              errorMsg = json.error || errorMsg;
            } catch (_) {}
          }
          bidFeedback.innerHTML = `<div class="alert alert-danger alert-dismissible fade show" role="alert"><i class="bi bi-exclamation-circle"></i> <strong>Error!</strong> ${errorMsg} <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
        }
      } catch (err) {
        bidFeedback.innerHTML = `<div class="alert alert-danger alert-dismissible fade show" role="alert"><i class="bi bi-exclamation-circle"></i> <strong>Error!</strong> ${err.message} <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
      } finally {
        submitBidBtn.disabled = false;
        submitBidBtn.innerHTML = originalText;
      }
    });

    if (window.io) {
      const socket = window.io();
      socket.emit('rfq:join', rfqId);
      socket.on('rfq:updated', (event) => {
        if (!event || event.rfqId !== rfqId) return;
        refreshRfqDetails();
      });
      window.addEventListener('beforeunload', () => {
        socket.emit('rfq:leave', rfqId);
      });
    }
  })();
</script>

<%- include('partials/foot') %>
